# Optional locally (SDK proxies through Claude Code CLI).
# Required for production/deployed use.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-6
# Optional: route the SDK briefing agent through a translation proxy.
# When ANTHROPIC_BASE_URL is set, AI_MODEL is the model NAME the proxy expects
# (e.g. gemini-2.5-pro for a LiteLLM proxy pointing at Vertex Gemini), not a
# real Claude id. Only the in-process + HTTP-MCP SDK paths follow this; the
# Managed Agents path stays on Anthropic.
# Example (LiteLLM, local): ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_AUTH_TOKEN is the proxy's auth (LiteLLM master key, or a dummy if
# the proxy has no auth). It is sent as a Bearer token to the CLI subprocess.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/build_ai_agents
DEBUG=false

# Claude Managed Agents beta
# Run: cd backend && uv run python ../scripts/setup_managed_agent.py
MANAGED_AGENT_ID=
MANAGED_ENVIRONMENT_ID=
MANAGED_AGENT_SESSION_TIMEOUT_SECONDS=240
MANAGED_AGENT_MAX_TOOL_ROUNDS=16

# RAG / Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=clinical_guidelines
QDRANT_API_KEY=

# Google AI Embeddings
# Google API key for Vertex AI embeddings (required for RAG).
GOOGLE_API_KEY=
GCP_PROJECT_ID=raman-gcp-project-k8s-dev
GCP_LOCATION=us-central1
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIMENSIONS=768

# External HTTP MCP server (third tool path; FastMCP over Streamable HTTP)
# Run: cd backend && uv run python -m mcp_server.server
# MCP_SERVER_HOST/PORT configure the standalone server; EXTERNAL_MCP_URL is
# where the briefing agent connects to reach it.
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=9000
EXTERNAL_MCP_URL=http://127.0.0.1:9000/mcp
EXTERNAL_MCP_AUTH_TOKEN=
